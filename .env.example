# TMDB v4 Read Access Token
# For GitHub Pages deployments, also add this as a repository secret named VITE_TMDB_BEARER_TOKEN.
VITE_TMDB_BEARER_TOKEN=replace_with_your_tmdb_read_access_token

# Optional override for GitHub Pages project base path.
# Leave blank for a custom domain rooted at /, such as castlink.app.
# GITHUB_PAGES_BASE_PATH=
